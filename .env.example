# ---- Keycloak (Person A) ----
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_HTTP_PORT=8180
KEYCLOAK_REALM=ztac
KEYCLOAK_GATEWAY_CLIENT_ID=ztac-gateway
KEYCLOAK_GATEWAY_CLIENT_SECRET=change-me-in-production
KEYCLOAK_CLI_CLIENT_ID=ztac-cli

# ---- Test users (Person A) ----
TEST_USER_ADMIN=alice
TEST_USER_ADMIN_PASSWORD=alice123
TEST_USER_ANALYST=bob
TEST_USER_ANALYST_PASSWORD=bob123
TEST_USER_VIEWER=charlie
TEST_USER_VIEWER_PASSWORD=charlie123

# ---- OPA (Person B) ----
OPA_HTTP_PORT=8181

# ---- Envoy (Person B) ----
ENVOY_HTTP_PORT=8080

# ---- ELK (Person A) ----
ES_HTTP_PORT=9200
ES_JAVA_OPTS=-Xms512m -Xmx512m
KIBANA_HTTP_PORT=5601
LOGSTASH_TCP_PORT=5044
LOGSTASH_HTTP_PORT=5050

# ---- Protected Service (Person A) ----
PROTECTED_SERVICE_PORT=8000

# ---- Internal trust secrets ----
# These are placeholders for a fresh checkout. scripts/bootstrap.sh replaces
# them with strong random values on first run. If you create .env by hand,
# generate your own:  openssl rand -hex 32
#
# Shared secret the api-gateway injects so the protected service can prove a
# request traversed the PEP/PA chain (closes the direct-access bypass).
INTERNAL_GATEWAY_SECRET=change-me-internal-gateway-secret
# Secret key for the HMAC-chained tamper-evident audit log.
AUDIT_HMAC_KEY=ztac-dev-audit-key
# Shared secret required to POST audit logs to the Logstash HTTP ingest.
LOGSTASH_INGEST_TOKEN=change-me-logstash-ingest-token
# Access tokens are only accepted from these authorized parties (azp).
JWT_ALLOWED_AZP=ztac-cli,ztac-gateway

# ---- Network ----
DOCKER_NETWORK=ztac-net
