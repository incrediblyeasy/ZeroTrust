# mTLS material — regenerated locally by scripts/generate-certs.sh.
# Never commit private keys or certs, but KEEP the directory present (via the
# tracked .gitkeep) so the Envoy image build (`COPY certs/`) succeeds on a
# fresh clone even before the certs have been generated.
envoy/certs/*
!envoy/certs/.gitkeep

# Never commit local backup files (may contain old secrets).
*.bak
